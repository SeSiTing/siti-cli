# siti shell wrapper - generated by siti-cli
# Enables commands like 'siti ai switch' and 'siti proxy on' to modify
# the current shell's environment variables transparently.
siti() {
  local out err_file exit_code
  err_file=$(mktemp)
  out=$(command siti "$@" 2>"$err_file")
  exit_code=$?
  if [ $exit_code -eq 10 ]; then
    [ -n "$out" ] && eval "$out"
    [ -s "$err_file" ] && cat "$err_file" >&2
    rm -f "$err_file"
    return 0
  else
    [ -s "$err_file" ] && cat "$err_file" >&2
    [ -n "$out" ] && echo "$out"
    rm -f "$err_file"
    return $exit_code
  fi
}