# siti shell wrapper for fish - generated by siti-cli
function siti
  set -l tmp (mktemp)
  set -l out (command siti $argv 2>$tmp)
  set -l code $status
  if test $code -eq 10
    test -n "$out"; and eval $out
    test -s $tmp; and cat $tmp >&2
    rm -f $tmp
    return 0
  else
    test -s $tmp; and cat $tmp >&2
    test -n "$out"; and echo $out
    rm -f $tmp
    return $code
  end
end